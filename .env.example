# ============================================================
# Mini Schedule Backend - Railway 环境变量模板
# 将此文件内容复制到 Railway 各服务的 Variables 面板
# 三个服务（api-brand / api-app / api-admin）共享同一套变量
# ============================================================

# ---- 应用 ----
MINI_SCHEDULE_APP_ENV=production
MINI_SCHEDULE_APP_DEBUG=false

# ---- 服务器（Railway 内部端口固定 8080，对外由 Railway 自动分配域名）----
MINI_SCHEDULE_SERVER_PORT=8080

# ---- PostgreSQL（直接使用 Railway 提供的 DATABASE_URL，或拆开填写）----
MINI_SCHEDULE_DATABASE_HOST=        # Railway Postgres 内网 host，例如 postgres.railway.internal
MINI_SCHEDULE_DATABASE_PORT=5432
MINI_SCHEDULE_DATABASE_USER=        # Railway 自动生成
MINI_SCHEDULE_DATABASE_PASSWORD=    # Railway 自动生成
MINI_SCHEDULE_DATABASE_DBNAME=mini_schedule
MINI_SCHEDULE_DATABASE_SSL_MODE=require   # Railway Postgres 要求 require
MINI_SCHEDULE_DATABASE_MAX_OPEN_CONNS=25
MINI_SCHEDULE_DATABASE_MAX_IDLE_CONNS=5

# ---- Redis（使用 Railway 提供的 Redis）----
MINI_SCHEDULE_REDIS_ADDR=           # 例如 redis.railway.internal:6379
MINI_SCHEDULE_REDIS_PASSWORD=       # Railway 自动生成
MINI_SCHEDULE_REDIS_DB=0

# ---- JWT（生产环境务必替换为强随机字符串，长度 ≥ 32 位）----
MINI_SCHEDULE_JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
MINI_SCHEDULE_JWT_EXPIRE=24h
MINI_SCHEDULE_JWT_REFRESH_EXPIRE=168h

# ---- 日志 ----
MINI_SCHEDULE_LOG_LEVEL=info
MINI_SCHEDULE_LOG_FORMAT=json
